# --- Raw data (DHS/MICS/survey files) — never commit ---
data/raw/**
!data/raw/.gitkeep
!data/raw/**/README.md

# --- Local geodata: shapefiles in data/shp/ are tracked (Honduras maps) ---
# Ignore everything in shp except README, gitkeep, and known shapefile sidecars
data/shp/**
!data/shp/.gitkeep
!data/shp/**/README.md
!data/shp/**/*.shp
!data/shp/**/*.shx
!data/shp/**/*.dbf
!data/shp/**/*.prj
!data/shp/**/*.cpg
!data/shp/**/*.qmd

# SAS transport > GitHub limit (also under raw/, but keep rule if copied elsewhere)
**/*.sas7bdat
**/*.SAS7BDAT

# Repo root data README stays tracked (do not ignore)
!data/README.md

# Derived: optional ignore for large RDS (comment out if you want derived in git)
# data/derived/**/*.rds

/submissions
.DS_Store
# Cursor IDE (keep rules if added; ignore debug logs)
.cursor/*.log

# Output temp files (e.g. editor locks)
output/~$*
output/*.tmp
